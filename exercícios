-- Seasonal Top Category (BI Analysis)
WITH estacoes AS (
    SELECT 
        CASE 
            WHEN SUBSTR(s.sale_date, 6, 2) IN ('12', '01', '02') THEN 'Winter'
            WHEN SUBSTR(s.sale_date, 6, 2) BETWEEN '03' AND '05' THEN 'Spring'
            WHEN SUBSTR(s.sale_date, 6, 2) BETWEEN '06' AND '08' THEN 'Summer'
            WHEN SUBSTR(s.sale_date, 6, 2) BETWEEN '09' AND '11' THEN 'Fall'
        END AS season,
        p.category,
        SUM(s.quantity) AS total_quantity,
        SUM(s.quantity * s.price) AS total_revenue
    FROM sales s
    JOIN products p ON s.product_id = p.product_id
    GROUP BY season, p.category
),
ordenando AS (
    SELECT season, category, total_quantity, total_revenue,
           ROW_NUMBER() OVER (
               PARTITION BY season 
               ORDER BY total_quantity DESC, total_revenue DESC, category ASC
           ) AS ln 
    FROM estacoes
)
SELECT season, category, total_quantity, total_revenue 
FROM ordenando 
WHERE ln = 1
ORDER BY season ASC;




-- Driver Efficiency Improvement (First vs Second Half)
WITH viagens AS (
    SELECT d.driver_id, d.driver_name, 
           AVG(CASE WHEN t.trip_date < '2023-07-01' THEN t.distance_km / NULLIF(t.fuel_consumed, 0) END) AS first_half_avg,
           AVG(CASE WHEN t.trip_date >= '2023-07-01' THEN t.distance_km / NULLIF(t.fuel_consumed, 0) END) AS second_half_avg,
           COUNT(CASE WHEN t.trip_date < '2023-07-01' THEN 1 END) AS via_1,
           COUNT(CASE WHEN t.trip_date >= '2023-07-01' THEN 1 END) AS via_2
    FROM drivers d
    JOIN trips t ON d.driver_id = t.driver_id
    WHERE t.trip_date BETWEEN '2023-01-01' AND '2023-12-31'
    GROUP BY d.driver_id, d.driver_name
    HAVING via_1 >= 1 AND via_2 >= 1
)
SELECT driver_id, driver_name,
       ROUND(first_half_avg, 2) AS first_half_avg,
       ROUND(second_half_avg, 2) AS second_half_avg, 
       ROUND(second_half_avg - first_half_avg, 2) AS efficiency_improvement 
FROM viagens
WHERE (second_half_avg - first_half_avg) >= 0
ORDER BY efficiency_improvement DESC, driver_name ASC;



-- Dominant User Reaction (Proportional Analysis)
WITH total_por_reacao AS (
    SELECT user_id, reaction, COUNT(reaction) AS qtde_por_reacao
    FROM reactions 
    GROUP BY user_id, reaction
),
total_reacoes AS (
    SELECT user_id, reaction, qtde_por_reacao,
           SUM(qtde_por_reacao) OVER (PARTITION BY user_id) AS qtde_total
    FROM total_por_reacao
)
SELECT user_id, reaction AS dominant_reaction, 
       ROUND(CAST(qtde_por_reacao AS FLOAT) / qtde_total, 2) AS reaction_ratio 
FROM total_reacoes
WHERE qtde_total >= 5 
