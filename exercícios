-- [1148] Capital Gain/Loss
WITH vendas AS (
    SELECT stock_name, SUM(price) AS sell FROM Stocks
    WHERE operation = 'Sell'
    GROUP BY stock_name    
)
SELECT s.stock_name, sell - SUM(price) AS capital_gain_loss FROM Stocks s
JOIN vendas v ON s.stock_name = v.stock_name
WHERE operation = 'Buy'
GROUP BY s.stock_name;



-- [1902] Count Salary Categories
WITH ordenando AS (
    SELECT 
        COUNT(CASE WHEN income > 50000 THEN 1 END) AS High_Salary,
        COUNT(CASE WHEN income >= 20000 AND income <= 50000 THEN 1 END) AS Average_Salary,
        COUNT(CASE WHEN income < 20000 THEN 1 END) AS Low_Salary
    FROM Accounts
)
SELECT 'High Salary' AS category, High_Salary AS accounts_count FROM ordenando
UNION ALL
SELECT 'Average Salary', Average_Salary FROM ordenando 
UNION ALL 
SELECT 'Low Salary', Low_Salary FROM ordenando;



-- [1204] Last Person to Fit in the Bus
-- Objetivo: Achar a última pessoa que pode entrar no ônibus sem exceder 1000kg.
WITH fila AS (
    SELECT person_name,
    SUM(weight) OVER (ORDER BY turn) AS soma
    FROM Queue
)
SELECT person_name FROM fila
WHERE soma <= 1000
ORDER BY soma DESC
LIMIT 1;



-- [1321] Restaurant Growth
-- Objetivo: Calcular a média móvel de gastos dos últimos 7 dias.
WITH soma_dia AS (
    SELECT visited_on, SUM(amount) AS soma
    FROM Customer
    GROUP BY visited_on
),
total_c AS (
    SELECT visited_on,
    SUM(soma) OVER (ORDER BY visited_on ASC ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS soma_movel
    FROM soma_dia
)
SELECT visited_on, 
       soma_movel AS amount,
       ROUND(soma_movel / 7, 2) AS average_amount 
FROM total_c
ORDER BY visited_on
LIMIT 6, 1000000; -- Pula os primeiros 6 dias para garantir janela de 7 dias



-- [3475] DNA Sequence Analysis
-- Objetivo: Identificar padrões específicos em sequências de DNA.
SELECT sample_id, dna_sequence, species, 
       CASE WHEN dna_sequence LIKE 'ATG%' THEN 1 ELSE 0 END AS has_start,
       CASE WHEN dna_sequence LIKE '%TAA' OR dna_sequence LIKE '%TAG' OR dna_sequence LIKE '%TGA' THEN 1 ELSE 0 END AS has_stop,
       CASE WHEN dna_sequence LIKE '%ATAT%' THEN 1 ELSE 0 END AS has_atat,
       CASE WHEN dna_sequence LIKE '%GGGG%' OR dna_sequence LIKE '%GGG%' THEN 1 ELSE 0 END AS has_ggg 
FROM Samples;



-- [3657] Customer Loyalty & Refund Rate
-- Objetivo: Filtrar clientes com alta taxa de reembolso e tempo mínimo de casa.
WITH clientes AS (
    SELECT customer_id,
           MIN(transaction_date) AS minimo,
           MAX(transaction_date) AS maximo,
           COUNT(CASE WHEN transaction_type = 'purchase' THEN transaction_id END) AS qtde_compras,
           COUNT(CASE WHEN transaction_type = 'refund' THEN transaction_id END) AS qtde_refunds,
           COUNT(transaction_id) AS qtde
    FROM customer_transactions
    GROUP BY customer_id
),
clientes_rate_20 AS (
    SELECT customer_id, 
           DATEDIFF(maximo, minimo) AS dias, 
           ROUND(qtde_refunds / qtde, 2) AS rate 
    FROM clientes
    WHERE qtde_compras >= 3 AND DATEDIFF(maximo, minimo) >= 30
)
SELECT customer_id FROM clientes_rate_20
WHERE rate < 0.2
ORDER BY customer_id ASC;



-- [3497] Trial to Paid Conversion Analysis
-- Objetivo: Média de duração de trial e pago apenas para usuários que completaram ambos.
SELECT user_id,
       ROUND(AVG(CASE WHEN activity_type = 'free_trial' THEN activity_duration END), 2) AS trial_avg_duration,
       ROUND(AVG(CASE WHEN activity_type = 'paid' THEN activity_duration END), 2) AS paid_avg_duration 
FROM UserActivity ua
WHERE EXISTS (
    SELECT 1 FROM UserActivity ua2 
    WHERE ua2.user_id = ua.user_id AND ua2.activity_type = 'free_trial'
)
AND EXISTS (
    SELECT 1 FROM UserActivity ua3 
    WHERE ua3.user_id = ua.user_id AND ua3.activity_type = 'paid'
)
GROUP BY user_id;



-- Performance Improvement Trend
-- Objetivo: Identificar funcionários com 3 avaliações consecutivas de crescimento.
WITH AvaliacoesRanqueadas AS (
    SELECT employee_id, name, rating, review_date,
           ROW_NUMBER() OVER (PARTITION BY employee_id ORDER BY review_date DESC) AS ordem_recente
    FROM employees e
    JOIN performance_reviews pr ON e.employee_id = pr.employee_id
),
UltimasTres AS (
    SELECT *,
           LEAD(rating, 1) OVER (PARTITION BY employee_id ORDER BY review_date DESC) AS nota_anterior,
           LEAD(rating, 2) OVER (PARTITION BY employee_id ORDER BY review_date DESC) AS nota_inicial
    FROM AvaliacoesRanqueadas
    WHERE ordem_recente <= 3
)
SELECT employee_id, name, (rating - nota_inicial) AS improvement_score
FROM UltimasTres
WHERE ordem_recente = 1 
  AND rating > nota_anterior 
  AND nota_anterior > nota_inicial
  AND nota_inicial IS NOT NULL
ORDER BY improvement_score DESC;



-- Student Progress Analysis
-- Objetivo: Comparar a primeira e a última nota de alunos em cada matéria.
WITH notas AS (
    SELECT *,
           FIRST_VALUE(score) OVER (PARTITION BY student_id, subject ORDER BY exam_date ASC) AS first_score,
           LAST_VALUE(score) OVER (PARTITION BY student_id, subject ORDER BY exam_date ASC 
                                  ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS latest_score,
           ROW_NUMBER() OVER (PARTITION BY student_id, subject ORDER BY exam_date ASC) AS linhas 
    FROM Scores s
    WHERE EXISTS (
        SELECT 1 FROM scores s2
        WHERE s.student_id = s2.student_id AND s.subject = s2.subject AND s.exam_date != s2.exam_date
    )
)
SELECT student_id, subject, first_score, latest_score FROM notas 
WHERE latest_score > first_score AND linhas = 1;



-- Market Basket Analysis
-- Objetivo: Identificar pares de produtos comprados frequentemente pelo mesmo usuário.
SELECT DISTINCT p1.product_id AS product1_id, p2.product_id AS product2_id, 
                pi1.category AS product1_category, pi2.category AS product2_category, 
                COUNT(DISTINCT p1.user_id) AS customer_count 
FROM ProductPurchases p1
JOIN ProductPurchases p2 ON p1.user_id = p2.user_id AND p1.product_id < p2.product_id
JOIN ProductInfo pi1 ON p1.product_id = pi1.product_id  
JOIN ProductInfo pi2 ON p2.product_id = pi2.product_id  
GROUP BY p1.product_id, p2.product_id  
HAVING COUNT(p1.user_id) >= 3
ORDER BY customer_count DESC, product1_id ASC;



-- Parity Transaction Sum
-- Objetivo: Somar valores de transações ímpares e pares separadamente.
SELECT transaction_date,
       COALESCE(SUM(CASE WHEN amount % 2 = 1 THEN amount END), 0) AS odd_sum,
       COALESCE(SUM(CASE WHEN amount % 2 = 0 THEN amount END), 0) AS even_sum
FROM transactions
GROUP BY transaction_date 
ORDER BY transaction_date;



