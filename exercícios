-- Inventory Imbalance (High Value vs Low Value Stock)
WITH qtde AS (
    SELECT i.store_id, s.store_name, s.location, i.product_name, i.price, i.quantity,
           ROW_NUMBER() OVER (PARTITION BY i.store_id ORDER BY i.price DESC) AS exp_p,
           ROW_NUMBER() OVER (PARTITION BY i.store_id ORDER BY i.price ASC) AS che_p,
           COUNT(*) OVER(PARTITION BY i.store_id) AS total
    FROM stores s
    JOIN inventory i ON s.store_id = i.store_id
),
expensive AS (
    SELECT store_id, product_name, quantity FROM qtde WHERE exp_p = 1 AND total >= 3
),
cheapest AS (
    SELECT store_id, product_name, quantity FROM qtde WHERE che_p = 1 AND total >= 3
)
SELECT e.store_id, q.store_name, q.location, e.product_name AS most_exp_product, 
       c.product_name AS cheapest_product,
       ROUND(1.0 * c.quantity / NULLIF(e.quantity, 0), 2) AS imbalance_ratio
FROM expensive e
JOIN cheapest c ON e.store_id = c.store_id
JOIN stores q ON e.store_id = q.store_id
WHERE e.quantity < c.quantity
ORDER BY imbalance_ratio DESC;



-- Churn Risk Analysis (Severe Downgrade Detection)
WITH planos AS (
    SELECT user_id, plan_name, event_date, event_type, monthly_amount,
           SUM(CASE WHEN event_type = 'downgrade' THEN 1 ELSE 0 END) OVER (PARTITION BY user_id) AS qtde_downgrade,
           LAG(event_type) OVER (PARTITION BY user_id ORDER BY event_date) AS ultimo_event
    FROM subscription_events
),
datas_plans AS (
    SELECT user_id, MIN(event_date) AS menor_data, MAX(event_date) AS maior_data, 
           MAX(monthly_amount) AS maior_val
    FROM subscription_events GROUP BY user_id
)
SELECT p.user_id, p.plan_name AS current_plan, p.monthly_amount AS current_monthly_amount, 
       d.maior_val AS max_historical_amount, DATEDIFF(d.maior_data, d.menor_data) AS days_as_subscriber
FROM planos p
JOIN datas_plans d ON p.user_id = d.user_id
WHERE p.event_type != 'cancel' 
  AND (p.ultimo_event != 'cancel' OR p.ultimo_event IS NULL)
  AND p.qtde_downgrade >= 1
  AND DATEDIFF(d.maior_data, d.menor_data) >= 60
  AND p.monthly_amount <= (d.maior_val * 0.50)
ORDER BY days_as_subscriber DESC, user_id ASC;



