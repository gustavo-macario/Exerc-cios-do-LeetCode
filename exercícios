-- [1321] Restaurant Growth
-- Objetivo: Calcular a média móvel de gastos dos últimos 7 dias.
WITH soma_dia AS (
    SELECT visited_on, SUM(amount) AS soma
    FROM Customer
    GROUP BY visited_on
),
total_c AS (
    SELECT visited_on,
    SUM(soma) OVER (ORDER BY visited_on ASC ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS soma_movel
    FROM soma_dia
)
SELECT visited_on, 
       soma_movel AS amount,
       ROUND(soma_movel / 7, 2) AS average_amount 
FROM total_c
ORDER BY visited_on
LIMIT 6, 1000000; -- Pula os primeiros 6 dias para garantir janela de 7 dias



